rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    match /users/{userId} {
      allow read, write, list: if true; 
    }
    
    match /healthRecords/{recordId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || getUserRole() == 'doctor' || getUserRole() == 'admin');
      allow create: if request.auth != null && (request.auth.uid == request.resource.data.userId || getUserRole() == 'doctor');
      allow delete: if request.auth != null && (request.auth.uid == resource.data.userId || getUserRole() == 'admin');
      allow list: if request.auth != null;
    }
    
    match /credentials/{credId} {
      allow read: if request.auth != null && getUserRole() == 'admin';
      allow write: if false;
    }
    
    match /appointments/{appointmentId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.patientId || request.auth.uid == resource.data.doctorId || getUserRole() == 'admin');
      allow list: if request.auth != null;
      allow create: if request.auth != null && (request.auth.uid == request.resource.data.patientId || getUserRole() == 'doctor' || getUserRole() == 'admin');
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.patientId || request.auth.uid == resource.data.doctorId || getUserRole() == 'admin');
    }

    match /medications/{medicationId} {
      // Allow public read for emergency card (unauthenticated first responders)
      allow read, list: if true;
      allow create: if request.auth != null && (request.auth.uid == request.resource.data.userId || getUserRole() == 'doctor' || getUserRole() == 'admin');
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.userId || getUserRole() == 'doctor' || getUserRole() == 'admin');
    }

    match /system/{document=**} {
      allow read, write: if request.auth != null && getUserRole() == 'admin';
    }
  }
}